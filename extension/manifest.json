{
    "manifest_version": 3,
    "name": "DSA Shadow",
    "version": "1.0",
    "description": "Track your real LeetCode progress",
    "permissions": [
        "storage",
        "activeTab"
    ],
    "content_scripts": [
        {
            "matches": [
                "https://leetcode.com/*"
            ],
            "js": [
                "content.js"
            ]
        },
        {
            "matches": [
                "https://dsa-shadow.vercel.app/*"
            ],
            "js": [
                "content.js"
            ]
        }
    ],
    "action": {
        "default_popup": "popup.html"
    }
}